<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="680" prefWidth="520" styleClass="root-pane" stylesheets="@../css/register.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="voxlink.client.src.main.ui.controllers.RegisterController">

    <VBox alignment="CENTER" styleClass="panel" HBox.hgrow="ALWAYS">
        <VBox alignment="TOP_LEFT" maxWidth="400" styleClass="form-card">
            <padding><Insets bottom="32" left="36" right="36" top="36" /></padding>

            <Label styleClass="brand-mark" text="VoxLink" />
            <Label styleClass="card-title" text="Create your account" />
            <Label styleClass="card-subtitle" text="Join your team workspace" />
            <Label fx:id="errorLabel" managed="false" maxWidth="Infinity" styleClass="error-label" visible="false" wrapText="true" />

            <VBox spacing="6">
                <Label styleClass="field-label" text="Username" />
                <TextField fx:id="usernameField" promptText="Choose a username" styleClass="vl-field" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Email" />
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="vl-field" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Password" />
                <PasswordField fx:id="passwordField" promptText="At least 6 characters" styleClass="vl-field" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Confirm password" />
                <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" styleClass="vl-field" />
            </VBox>

            <Button fx:id="registerButton" defaultButton="true" maxWidth="Infinity" onAction="#onRegister" styleClass="btn-primary" text="Register" />

            <HBox alignment="CENTER" spacing="4">
                <Label styleClass="prompt-text" text="Already have an account?" />
                <Hyperlink onAction="#onGoToLogin" styleClass="accent-link" text="Sign in" />
            </HBox>
        </VBox>
    </VBox>
</HBox>
