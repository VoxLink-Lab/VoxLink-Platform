<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="580" prefWidth="900" styleClass="login-root" stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="voxlink.client.src.main.ui.controllers.LoginController">

    <VBox alignment="CENTER" minWidth="360" prefWidth="400" styleClass="left-panel" HBox.hgrow="ALWAYS">
        <padding><Insets bottom="48" left="48" right="48" top="48" /></padding>
        <Label styleClass="brand-logo" text="VoxLink" />
        <Text fill="#e8e8f0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="brand-tagline" text="Connect. Communicate. Collaborate." textAlignment="CENTER" wrappingWidth="320">
            <font><Font name="Segoe UI" size="14.0" /></font>
        </Text>
        <Region prefHeight="32" />
        <VBox alignment="CENTER" styleClass="brand-feature-card">
            <padding><Insets bottom="24" left="24" right="24" top="24" /></padding>
            <Label styleClass="brand-feature-title" text="Enterprise-grade workspaces" />
            <Label styleClass="brand-feature-body" text="Nested servers, channels, roles, and real-time sync — built for your Advanced Programming course project." wrapText="true" />
        </VBox>
    </VBox>

    <VBox alignment="CENTER" styleClass="right-panel" HBox.hgrow="ALWAYS">
        <VBox alignment="TOP_LEFT" maxWidth="400" styleClass="form-card">
            <padding><Insets bottom="32" left="36" right="36" top="36" /></padding>
            <Label fx:id="errorLabel" managed="false" styleClass="error-label" visible="false" wrapText="true" />
            <Label styleClass="card-title" text="Welcome back" />
            <Label styleClass="card-subtitle" text="Sign in to continue" />
            <Region prefHeight="8" />

            <VBox spacing="6">
                <Label styleClass="field-label" text="Username" />
                <TextField fx:id="usernameField" promptText="Enter your username" styleClass="vl-field" />
                <Label fx:id="usernameErrorLabel" managed="false" styleClass="field-error" visible="false" />
            </VBox>

            <VBox spacing="6">
                <Label styleClass="field-label" text="Password" />
                <HBox styleClass="password-field-container">
                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="password-field" HBox.hgrow="ALWAYS" />
                    <ToggleButton fx:id="toggleButton" styleClass="toggle-password" text="👁" />
                </HBox>
                <Label fx:id="passwordErrorLabel" managed="false" styleClass="field-error" visible="false" />
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Hyperlink fx:id="forgotPasswordLink" onAction="#onForgotPassword" styleClass="forgot-link" text="Forgot password?" />
            </HBox>

            <Button fx:id="loginButton" defaultButton="true" maxWidth="Infinity" onAction="#onLogin" styleClass="btn-primary" text="Login" />
            <HBox alignment="CENTER" spacing="4">
                <Label styleClass="register-prompt" text="Don't have an account?" />
                <Hyperlink onAction="#onGoToRegister" styleClass="register-link" text="Register" />
            </HBox>
        </VBox>
    </VBox>
</HBox>
