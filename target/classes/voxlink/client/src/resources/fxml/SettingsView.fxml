<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="600.0" prefWidth="800.0" styleClass="settings-root" stylesheets="@../css/settings.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="voxlink.client.src.main.ui.controllers.SettingsController">

    <!-- Sidebar -->
    <VBox prefWidth="250.0" styleClass="settings-sidebar" spacing="2.0">
        <Label styleClass="settings-subheader" text="USER SETTINGS">
            <padding>
                <Insets left="10.0" bottom="5.0" />
            </padding>
        </Label>
        
        <Button text="My Account" styleClass="settings-sidebar-item, settings-sidebar-item-active" maxWidth="Infinity" alignment="BASELINE_LEFT" />
        <Button text="Profiles" styleClass="settings-sidebar-item" maxWidth="Infinity" alignment="BASELINE_LEFT" />
        <Button text="Privacy &amp; Safety" styleClass="settings-sidebar-item" maxWidth="Infinity" alignment="BASELINE_LEFT" />
        
        <Separator style="-fx-background-color: #4f545c; -fx-opacity: 0.3;">
            <padding><Insets top="10.0" bottom="10.0" /></padding>
        </Separator>
        
        <Button text="Log Out" styleClass="settings-sidebar-item, settings-sidebar-logout" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#onLogOut" />
    </VBox>

    <!-- Main Content Area -->
    <StackPane HBox.hgrow="ALWAYS">
        <VBox styleClass="settings-content" spacing="20.0">
            <Label styleClass="settings-header" text="My Account" />
            
            <VBox styleClass="profile-card">
                <!-- Banner -->
                <Region styleClass="profile-banner" />
                
                <!-- Info Section -->
                <HBox styleClass="profile-info-section" spacing="16.0">
                    <!-- Floating Avatar (pulls up into banner) -->
                    <StackPane translateY="-40.0" alignment="TOP_LEFT">
                        <Label fx:id="avatarLabel" text="U" styleClass="profile-avatar-large" prefWidth="80.0" prefHeight="80.0" />
                    </StackPane>
                    
                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="usernameLabel" styleClass="profile-username" text="Username" />
                        <Label fx:id="emailLabel" styleClass="profile-email" text="email@example.com" />
                    </VBox>
                    
                    <Button text="Edit User Profile" styleClass="settings-btn-primary" />
                </HBox>
                
                <!-- Inner details card -->
                <VBox style="-fx-background-color: #2f3136; -fx-background-radius: 8px; -fx-padding: 16px;" spacing="16.0">
                    <VBox.margin>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="-20.0" />
                    </VBox.margin>
                    
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label styleClass="settings-subheader" text="DISPLAY NAME" />
                            <Label fx:id="displayNameLabel" style="-fx-text-fill: #ffffff; -fx-font-size: 16px;" text="Display Name" />
                        </VBox>
                        <Button text="Edit" styleClass="settings-btn-primary" style="-fx-background-color: #4f545c;" />
                    </HBox>
                    
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label styleClass="settings-subheader" text="USERNAME" />
                            <Label fx:id="usernameDetailedLabel" style="-fx-text-fill: #ffffff; -fx-font-size: 16px;" text="Username" />
                        </VBox>
                        <Button text="Edit" styleClass="settings-btn-primary" style="-fx-background-color: #4f545c;" />
                    </HBox>
                </VBox>
            </VBox>
            
            <Separator style="-fx-background-color: #4f545c; -fx-opacity: 0.3;">
                <padding><Insets top="20.0" bottom="20.0" /></padding>
            </Separator>
            
            <Label styleClass="settings-header" text="Account Removal" style="-fx-font-size: 16px; -fx-padding: 0;" />
            <Label text="Disabling your account means you can recover it at any time after taking this action." style="-fx-text-fill: #b9bbbe;" wrapText="true" />
            
            <HBox spacing="16.0">
                <Button text="Disable Account" styleClass="settings-btn-danger" />
                <Button text="Delete Account" styleClass="settings-btn-danger" />
            </HBox>
        </VBox>
        
        <!-- Close Button (Top Right) -->
        <VBox alignment="TOP_RIGHT" pickOnBounds="false">
            <padding>
                <Insets top="40.0" right="40.0" />
            </padding>
            <VBox alignment="CENTER" spacing="5.0">
                <Button text="✕" styleClass="settings-close-btn" onAction="#onClose" />
                <Label text="ESC" style="-fx-text-fill: #72767d; -fx-font-weight: bold; -fx-font-size: 11px;" />
            </VBox>
        </VBox>
    </StackPane>
</HBox>
